@article{verweij2023ModifiedDelphiStudy,
  title = {A Modified {{Delphi}} Study to Identify Which Items Should Be Evaluated in Shoulder Instability Research: A First Step in Developing a Core Outcome Set},
  shorttitle = {A Modified {{Delphi}} Study to Identify Which Items Should Be Evaluated in Shoulder Instability Research},
  author = {Verweij, Lukas P. E. and Sierevelt, Inger N. and Baden, David N. and Derksen, Robert Jan and {van der Woude}, Henk-Jan and Hekman, Karin M. C. and {van den Bekerom}, Michel P. J. and {van den Borne}, M. and {van der Linde}, J. A. and {van Deurzen}, D. F. P. and {van der Meijden}, O. A. J. and Alta, T. D. W. and Muller, B. and Floor, S. and Wessel, R. N. and {van Noort}, A. and Kooistra, B. W. and Gosens, T. and Kleinlugtenbelt, Y. V. and Berendes, T. D. and {van der Veen}, H. C. and Visser, C. and {van den Brand}, C. L. and {Wildevuur-Houthoff}, A. M. L. and Wei, A. and Verbeek, R. and Barten, D. G. and Verdonschot, R. J. C. G. and Boeije, T. and Roodheuvel, F. and {Huis in 't Veld}, M. A. and R{\"o}ttger, E. and Versteegen, M. and Douma, D. and {Azijli -- Abdellaoui}, K. and Walraven, L. and Boden, R. and Sluijter, N. and {van Gastel}, M. L. and {van den Berg}, W. and {Jansen-Oskam}, P. and Haas, I. S. and Nes, H. and Koel, G. and Hessel, B. and Heijblok, D. and Husen, I. M. and Numan, M. and Boon, F.},
  year = 2023,
  month = nov,
  journal = {JSES International},
  volume = {7},
  number = {6},
  pages = {2304--2310},
  issn = {2666-6383},
  doi = {10.1016/j.jseint.2023.06.012},
  urldate = {2026-03-31},
  abstract = {Background The aim of this study was to identify items that healthcare providers and/or patients consider important to include in a questionnaire for clinical trials and cohort studies in shoulder instability research. This could serve as a basis to develop a core outcome set for shoulder instability research. Methods Healthcare providers and patients were included in a panel for a modified Delphi consensus study. The study consisted of three rounds, comprising (1) identifying items, (2) rating the importance of the items, and (3) rating the importance again after seeing a summary of the results of round two. Importance was rated on a 9-point Likert scale. Consensus was defined as {$\geq$} 80\% of the panel giving a score of 7 or higher. Results In total, 44 healthcare providers and 30 patients completed all three rounds. Round one identified 54 items. After round three, the panel reached a consensus on 11 items that should be included in a questionnaire, comprising re-dislocation (99\%), instable feeling of the shoulder (96\%), limitations during sport (93\%), patient satisfaction with the shoulder (93\%), fear/anxiety for re-dislocation (91\%), range of motion (88\%), return to old level of functioning (85\%), performing daily activities (85\%), return to sport (82\%), return to work (82\%), and trusting the shoulder (81\%). Conclusion Healthcare providers and patients reached a consensus on 11 items that should be included in a questionnaire for shoulder instability research. These items can facilitate design and development of future clinical trials and form the basis for the development of a core outcome set.},
  keywords = {Consensus,Core outcome set,Delphi,Dislocation,Instability,Outcome,Shoulder},
  annotation = {verweij2023ModifiedDelphiStudy\\
verweij2023ModifiedDelphiStudy},
  file = {/Users/pavol.bielik/Zotero/storage/RJ5FDRWN/Verweij et al. - 2023 - A modified Delphi study to identify which items should be evaluated in shoulder instability research.pdf;/Users/pavol.bielik/Zotero/storage/V4CV8WAQ/S2666638323001585.html}
}

