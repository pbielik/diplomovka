  keywords = {llm,must-read,seeding},
  annotation = {obradovich2024llmpsychiatry},
  file = {/Users/pavol.bielik/Zotero/storage/SVSL5P42/Obradovich et al. - 2024 - Opportunities and risks of large language models in psychiatry.pdf}
}

@article{omar2024llmpsychiatry,
  title = {Applications of Large Language Models in Psychiatry: A Systematic Review},
  shorttitle = {Applications of Large Language Models in Psychiatry},
  author = {Omar, Mahmud and Soffer, Shelly and Charney, Alexander W. and Landi, Isotta and Nadkarni, Girish N. and Klang, Eyal},
  year = 2024,
  journal = {Frontiers in Psychiatry},
  volume = {15},
  doi = {10.3389/fpsyt.2024.1422807},
  urldate = {2026-03-30},
  abstract = {With their unmatched ability to interpret and engage with human language and context, large language models (LLMs) hint at the potential to bridge AI and human cognitive processes. This review explores the current application of LLMs, such as ChatGPT, in the field of psychiatry. We followed PRISMA guidelines and searched through PubMed, Embase, Web of Science, and Scopus, up until March 2024. From 771 retrieved articles, we included 16 that directly examine LLMs' use in psychiatry. LLMs, particularly ChatGPT and GPT-4, showed diverse applications in clinical reasoning, social media, and education within psychiatry. They can assist in diagnosing mental health issues, managing depression, evaluating suicide risk, and supporting education in the field. However, our review also points out their limitations, such as difficulties with complex cases and potential underestimation of suicide risks. Early research in psychiatry reveals LLMs' versatile applications, from diagnostic support to educational roles. Given the rapid pace of advancement, future investigations are poised to explore the extent to which these models might redefine traditional roles in mental health care.},
  langid = {english},
  keywords = {llm,seeding,should-read},
  annotation = {omar2024llmpsychiatry},
  file = {/Users/pavol.bielik/Zotero/storage/LLBR7D9L/Omar et al. - 2024 - Applications of large language models in psychiatry a systematic review.pdf;/Users/pavol.bielik/Zotero/storage/M7CJ39RE/10.3389fpsyt.2024.html}
}

